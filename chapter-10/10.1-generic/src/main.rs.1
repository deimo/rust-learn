fn main() {
    let number_list = vec![34, 50, 100, 65];

    let a = largest1(&number_list);
    println!("a is {}", a);
    let b = largest2(&number_list);
    println!("b is {}", b);

    let number_list2 = vec![102, 34, 6000, 89, 54, 2, 32, 8];
    let c = largest2(&number_list2);
    println!("c is {}", c);
}


fn largest1(list: &Vec<i32>) -> i32 {
    let mut res = list[0];
    for &item in list {
        if item > res {
            res = item;
        }
    }
    res
}


fn largest2(list: &[i32]) -> i32 {
    let mut largest = list[0];
    for &item in list {
        if item > largest {
            largest = item;
        }
    }
    largest
}