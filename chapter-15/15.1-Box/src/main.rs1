/// Box<T>智能指针 
/// 使用场景
/// 1. 编译时，某类型的大小无法确定。但使用该类型时，上下文却需要知道它的确切大小
/// 2. 有大量数据，想移交所有权，但需要确保在操作时数据不会被复制。
/// 3. 使用某个值时，之用关心是否实现了特定的trait，不用关心它的具体类型

fn main() {
    // println!(">>>>")
    /* 例1： Box类型的最简单应用 */
    let b1 = 5; // 数据会存储在stack上
    let b2 = Box::new(5); // 此时数据就会存储与heap上
    println!("b2: {}", b2);

}